{
  "name": "markdown-formatter",
  "version": "1.0.0",
  "description": "Tools for formatting Markdown to GFM standard",
  "scripts": {
    "format": "fix-tables.js && npx markdownlint-cli2 --fix",
    "format:table": "fix-tables.js",
    "format:table:all": "fix-tables.js --all .",
    "format:lint": "npx markdownlint-cli2 --fix",
    "format:lint:all": "npx markdownlint-cli2 . --fix"
  },
  "devDependencies": {
    "glob": "^10.3.0",
    "markdownlint-cli2": "^1.1.0"
  },
  "keywords": ["markdown", "gfm", "formatter", "lint"],
  "license": "MIT"
}