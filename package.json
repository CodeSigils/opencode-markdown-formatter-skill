{
  "name": "markdown-formatter",
  "version": "1.0.0",
  "description": "Tools for formatting Markdown to GFM standard (requires npm install)",
  "scripts": {
    "format": "node references/fix-tables.js && npx markdownlint-cli2 --fix",
    "format:table": "node references/fix-tables.js",
    "format:table:all": "node references/fix-tables.js --all .",
    "format:lint": "npx markdownlint-cli2 --fix",
    "format:lint:all": "npx markdownlint-cli2 . --fix"
  },
  "devDependencies": {
    "markdownlint-cli2": "^1.1.0"
  },
  "keywords": ["markdown", "gfm", "formatter", "lint"],
  "license": "MIT"
}